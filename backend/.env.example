# ============================================
# Reverse Match Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# All variables marked [REQUIRED] must be set.
# Variables marked [OPTIONAL] have defaults.

# ---- Core ----
NODE_ENV=development                         # [OPTIONAL] development | staging | production
PORT=5000                                    # [OPTIONAL] Default: 5000

# ---- MongoDB [REQUIRED] ----
MONGO_URI=mongodb://localhost:27017/reverse_match

# ---- Redis [REQUIRED in production] ----
# Redis is mandatory in production for rate limiting, caching, and socket scaling.
# In development, the server will start without it but with degraded functionality.
REDIS_URL=redis://localhost:6379

# ---- JWT [REQUIRED] ----
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m                        # [OPTIONAL] Default: 15m
JWT_REFRESH_EXPIRY=7d                        # [OPTIONAL] Default: 7d

# ---- Google OAuth [OPTIONAL] ----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ---- Email / OTP [OPTIONAL — logs OTP to console if not set] ----
SMTP_HOST=smtp.gmail.com                     # [OPTIONAL] Default: smtp.gmail.com
SMTP_PORT=587                                # [OPTIONAL] Default: 587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
OTP_EXPIRY_MINUTES=5                         # [OPTIONAL] Default: 5

# ---- Cloudinary [REQUIRED for photo uploads] ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_MODERATION=false                  # [OPTIONAL] Set to 'true' to enable AI image moderation (requires Cloudinary paid plan)

# ---- Firebase [OPTIONAL — push notifications] ----
# Download service account JSON from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ---- Stripe [OPTIONAL — boost payments] ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- App URLs ----
APP_BASE_URL=http://localhost:5000           # [REQUIRED in production] Your backend public URL (e.g., https://api.yourdomain.com)
APP_DEEP_LINK_SCHEME=reversematch            # [OPTIONAL] Deep link scheme registered in Flutter app

# ---- Legal Pages ----
PRIVACY_POLICY_URL=                          # [REQUIRED for app store] e.g., https://yourdomain.com/privacy
TERMS_OF_SERVICE_URL=                        # [REQUIRED for app store] e.g., https://yourdomain.com/terms

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000           # [OPTIONAL] Comma-separated allowed origins. In dev mode, all origins allowed.

# ---- Sentry [OPTIONAL — error tracking] ----
SENTRY_DSN=

# ---- Rate Limiting ----
LIKE_RATE_LIMIT_WINDOW_MS=3600000            # [OPTIONAL] Default: 1 hour (ms)
LIKE_RATE_LIMIT_MAX=100                      # [OPTIONAL] Default: 100 likes per window

# ---- Request Limits ----
MAX_REQUEST_BODY_SIZE=10mb                   # [OPTIONAL] Default: 10mb
SOCKET_MAX_PAYLOAD_BYTES=65536               # [OPTIONAL] Default: 64KB
