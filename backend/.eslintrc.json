{
  "extends": ["airbnb-base"],
  "env": { "node": true, "es2022": true, "jest": true },
  "parserOptions": { "ecmaVersion": 2022 },
  "rules": {
    "no-underscore-dangle": ["error", { "allow": ["_id"] }],
    "no-console": "warn",
    "import/no-extraneous-dependencies": ["error", { "devDependencies": ["**/__tests__/**"] }]
  }
}
